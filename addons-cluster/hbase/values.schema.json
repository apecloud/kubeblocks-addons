{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "topology": {
      "type": "string",
      "enum": [
        "cluster",
        "standalone"
      ],
      "default": "cluster"
    },
    "replicas": {
      "type": "object",
      "properties": {
        "hmaster": {
          "type": "integer",
          "default": 2,
          "minimum": 1
        },
        "hregionserver": {
          "type": "integer",
          "default": 2,
          "minimum": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "hmaster": {
          "$ref": "#/definitions/resourceSchema"
        },
        "hregionserver": {
          "$ref": "#/definitions/resourceSchema"
        },
        "hbasestandalone": {
          "$ref": "#/definitions/resourceSchema"
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "storageClassName": {
          "type": "string",
          "default": ""
        },
        "standalone": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string",
              "default": "20Gi"
            }
          }
        }
      }
    },
    "serviceRefs": {
      "type": "object",
      "properties": {
        "hbaseZookeeper": {
          "$ref": "#/definitions/serviceRefSchema"
        },
        "hdfsNamenode": {
          "$ref": "#/definitions/serviceRefSchema"
        }
      }
    },
    "hdfs": {
      "type": "object",
      "properties": {
        "namenodeNodes": {
          "type": "string",
          "default": "nn0,nn1"
        },
        "namenodeRpcPort": {
          "type": "integer",
          "default": 8020,
          "minimum": 1,
          "maximum": 65535
        },
        "namenodeHttpPort": {
          "type": "integer",
          "default": 9870,
          "minimum": 1,
          "maximum": 65535
        },
        "haZkParent": {
          "type": "string",
          "default": "/hadoop-ha"
        },
        "replication": {
          "type": "string",
          "default": "3"
        },
        "permissionsEnabled": {
          "type": "boolean",
          "default": false
        },
        "fs": {
          "type": "object",
          "properties": {
            "trashInterval": {
              "type": "integer",
              "default": 1440,
              "minimum": 0
            }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "authentication": {
              "type": "string",
              "default": "simple"
            },
            "authorization": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "ipc": {
          "type": "object",
          "properties": {
            "clientConnectionMaxIdleTime": {
              "type": "integer",
              "default": 30000,
              "minimum": 0
            },
            "clientConnectTimeout": {
              "type": "integer",
              "default": 10000,
              "minimum": 1
            },
            "pingInterval": {
              "type": "integer",
              "default": 60000,
              "minimum": 1
            }
          }
        },
        "paths": {
          "type": "object",
          "properties": {
            "tmpDir": {
              "type": "string",
              "default": "/hadoop/tmp"
            }
          }
        },
        "client": {
          "type": "object",
          "properties": {
            "webhdfsEnabled": {
              "type": "boolean",
              "default": false
            },
            "failoverMaxAttempts": {
              "type": "integer",
              "default": 15,
              "minimum": 1
            },
            "failoverSleepBaseMillis": {
              "type": "integer",
              "default": 500,
              "minimum": 0
            },
            "failoverSleepMaxMillis": {
              "type": "integer",
              "default": 15000,
              "minimum": 0
            },
            "retryPolicy": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "spec": {
                  "type": "string",
                  "default": "10000,6,60000,10"
                }
              }
            },
            "commonRetryPolicy": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "spec": {
                  "type": "string",
                  "default": "1000,1"
                }
              }
            }
          }
        },
        "hbaseClient": {
          "type": "object",
          "properties": {
            "ipcClientConnectTimeout": {
              "type": "integer",
              "default": 30000,
              "minimum": 1
            },
            "ipcClientConnectMaxRetries": {
              "type": "integer",
              "default": 10,
              "minimum": 0
            }
          }
        }
      }
    },
    "hbase": {
      "type": "object",
      "properties": {
        "zk": {
          "type": "object",
          "properties": {
            "sessionTimeout": {
              "type": "integer",
              "default": 30000,
              "minimum": 1
            },
            "maxClientCnxns": {
              "type": "integer",
              "default": 4000,
              "minimum": 1
            }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "authentication": {
              "type": "string",
              "default": "simple"
            },
            "authorization": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "common": {
          "type": "object",
          "properties": {
            "clientScannerCaching": {
              "type": "integer",
              "default": 100,
              "minimum": 1
            },
            "regionMemstoreFlushSize": {
              "type": "integer",
              "default": 134217728,
              "minimum": 1
            }
          }
        },
        "cluster": {
          "type": "object",
          "properties": {
            "regionserverHandlerCount": {
              "type": "integer",
              "default": 100,
              "minimum": 1
            },
            "hstoreFlusherCount": {
              "type": "integer",
              "default": 4,
              "minimum": 1
            },
            "regionMaxFileSize": {
              "type": "integer",
              "default": 53687091200,
              "minimum": 1
            },
            "regionMajorCompaction": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            },
            "masterWaitOnRegionserversTimeout": {
              "type": "integer",
              "default": 300000,
              "minimum": 0
            },
            "masterStartupRetainassignTimeout": {
              "type": "integer",
              "default": 300000,
              "minimum": 0
            },
            "oldWalsCleanerThreadTimeoutMsec": {
              "type": "integer",
              "default": 60000,
              "minimum": 0
            },
            "masterLogCleanerTtl": {
              "type": "integer",
              "default": 60000,
              "minimum": 0
            },
            "masterHfileCleanerTtl": {
              "type": "integer",
              "default": 600000,
              "minimum": 0
            },
            "balancerPeriod": {
              "type": "integer",
              "default": 1800000,
              "minimum": 0
            },
            "procedureStoreWalUseHsync": {
              "type": "boolean",
              "default": true
            },
            "regionserverOptionalCacheFlushInterval": {
              "type": "integer",
              "default": 28800000,
              "minimum": 0
            },
            "regionserverStartupRetries": {
              "type": "integer",
              "default": 10,
              "minimum": 0
            },
            "regionserverStartupRetryInterval": {
              "type": "integer",
              "default": 10000,
              "minimum": 0
            },
            "replicationEnabled": {
              "type": "boolean",
              "default": true
            },
            "splitlogManagerTimeout": {
              "type": "integer",
              "default": 600000,
              "minimum": 0
            }
          }
        },
        "standalone": {
          "type": "object",
          "properties": {
            "regionserverHandlerCount": {
              "type": "integer",
              "default": 30,
              "minimum": 1
            },
            "hstoreFlusherCount": {
              "type": "integer",
              "default": 2,
              "minimum": 1
            },
            "regionMaxFileSize": {
              "type": "integer",
              "default": 10737418240,
              "minimum": 1
            },
            "procedureStoreWalUseHsync": {
              "type": "boolean",
              "default": false
            },
            "replicationEnabled": {
              "type": "boolean",
              "default": false
            }
          }
        }
      }
    },
    "prometheus": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "definitions": {
    "resourceSchema": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "0.5"
            },
            "memory": {
              "type": "string",
              "default": "1Gi"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "2"
            },
            "memory": {
              "type": "string",
              "default": "4Gi"
            }
          }
        }
      }
    },
    "serviceRefSchema": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string",
          "default": "kubeblocks"
        },
        "clusterServiceSelector": {
          "type": "object",
          "properties": {
            "cluster": {
              "type": "string"
            },
            "service": {
              "type": "object",
              "properties": {
                "component": {
                  "type": "string"
                },
                "service": {
                  "type": "string",
                  "default": "headless"
                },
                "port": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}