{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "topology": {
      "type": "string",
      "enum": [
        "cluster",
        "standalone"
      ],
      "default": "cluster"
    },
    "replicas": {
      "type": "object",
      "properties": {
        "hmaster": {
          "type": "integer",
          "default": 2,
          "minimum": 1
        },
        "hregionserver": {
          "type": "integer",
          "default": 2,
          "minimum": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "hmaster": {
          "$ref": "#/definitions/resourceSchema"
        },
        "hregionserver": {
          "$ref": "#/definitions/resourceSchema"
        },
        "hbasestandalone": {
          "$ref": "#/definitions/resourceSchema"
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "storageClassName": {
          "type": "string",
          "default": ""
        },
        "standalone": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string",
              "default": "20Gi"
            }
          }
        }
      }
    },
    "serviceRefs": {
      "type": "object",
      "properties": {
        "hbaseZookeeper": {
          "$ref": "#/definitions/serviceRefSchema"
        },
        "hdfsNamenode": {
          "$ref": "#/definitions/serviceRefSchema"
        }
      }
    }
  },
  "definitions": {
    "resourceSchema": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "0.5"
            },
            "memory": {
              "type": "string",
              "default": "1Gi"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "2"
            },
            "memory": {
              "type": "string",
              "default": "4Gi"
            }
          }
        }
      }
    },
    "serviceRefSchema": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string",
          "default": "kubeblocks"
        },
        "clusterServiceSelector": {
          "type": "object",
          "properties": {
            "cluster": {
              "type": "string"
            },
            "service": {
              "type": "object",
              "properties": {
                "component": {
                  "type": "string"
                },
                "service": {
                  "type": "string",
                  "default": "headless"
                },
                "port": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}